<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.board.mapper.CategorieMapper">

	<select id="getSelectCategorie"
		resultType="com.example.board.dto.CategorieResponseDto">
		SELECT id, name
		FROM categories
		where 1=1;
	</select>

</mapper>